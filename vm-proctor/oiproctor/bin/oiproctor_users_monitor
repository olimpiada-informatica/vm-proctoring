#!/bin/node

const CONFIG_PATH   	= '/opt/oiproctor/etc/config';
const MANDATORY_PARAMS  = [ 'listen_port', 'listen_host', 'cms_contest_shortname', 'proctor_connections_path', 'proctor_users_path', 'proctor_log_users_path', 'title', 'ping_interval', 'update_allowlist', 'cms_users' ];

const http  	= require('http');
const fs    	= require('fs');
const { exec }	= require("child_process");

const config	= {};
var users_map   = { ips: {}, usernames: {}, };
var cache   	= {};
var alerts      = [];

function date_formatted(date = new Date()) {

	const now   	= typeof date === 'object' ? date : new Date(date);

	const year  	= now.getFullYear();
	const month 	= String(now.getMonth() + 1).padStart(2, '0');
	const day   	= String(now.getDate() 	).padStart(2, '0');
	const hours 	= String(now.getHours()	).padStart(2, '0');
	const minutes   = String(now.getMinutes()  ).padStart(2, '0');
	const seconds   = String(now.getSeconds()  ).padStart(2, '0');

	return year + '-' + month + '-' + day + ' ' + hours + ':' + minutes + ':' + seconds;

}

function add_alert(ip, msg) {

	alerts.push({ timestamp: Date.now(), ip: ip, message: msg });

	const msg_text = [ date_formatted(), ip, msg, ].join('\t');
	fs.appendFileSync(
		config.proctor_log_users_path,
		msg_text + '\n',
	);
	console.warn(msg_text);

}

const requestListener = function (req, res) {

	const params = new URLSearchParams(req.url.split('?').slice(1).join('?'));

	const monitor = (req, res) => {

		const since       = parseInt(params.get('since'));

		let output = "";
		output  += `<!DOCTYPE html><html><head><title>${config.title}</title><meta http-equiv="refresh" content="${config.ping_interval}"></head><body>`;

		output  += '<style>.timestamp, .user, .message { display: inline-block; margin: 0 1em; }</style>';

		alerts.forEach(alert => {
			if (since && since < alert.timestamp) return;
			output += `<div><div class="timestamp">${date_formatted(alert.timestamp)}</div><div class="user">${alert.ip}</div><div class="message">${alert.message}</div></div>`;
		});

		output  += '</body></html>';
		res.write(output);

	};

	const notify = (req, res) => {

		const msg       = params.get('msg');

		if (!msg) return res.write('{ "error": "Missing msg" }');

		const ip        = req.headers['x-forwarded-for'] || req.socket.remoteAddress;

		if (!ip.match(new RegExp(config.update_allowlist)) && !ip.match(new RegExp(config.update_whitelist))) return console.error(`Invalid source IP ${ip} trying to notiy ${msg}`);

		add_alert(ip, msg);

		res.write('{ "success": true }');

	};

	const update = (req, res) => {

		const username 	= params.get(config.cms_contest_shortname + '_login');

		if (!username) return;
		if (!config.cms_users.includes(username)) return; // Whitelist to prevent http requests poisoning the dns

		const ip    	= req.headers['x-forwarded-for'] || req.socket.remoteAddress;

		if (!ip.match(new RegExp(config.update_allowlist)) && !ip.match(new RegExp(config.update_whitelist))) return console.error(`Invalid source IP ${ip} trying to register ${username}`);

		const user_obj  = { username: username, ip: ip, timestamp: Date.now(), };

		if (users_map.ips[ip]?.username === username) {
			users_map.ips[ip] = user_obj;
			return;
		}

		const old_usernames_ip = users_map.usernames[username];
		users_map.usernames[username] = ip;

		const old_username  = users_map.ips[ip]?.username;
		let old_ips_ip  	    = Object.keys(users_map.ips).find(k => users_map.ips[k].username == username);
		if (old_ips_ip) {
			delete users_map.ips[old_ips_ip];
		}

		if (old_username && old_username != username) {
			add_alert(ip, `Known IP switched user: ${old_username} > ${username}`);
		}
		if ((old_ips_ip ?? old_usernames_ip) !== ip) {
			add_alert(ip, `Known user found in new IP: ${username} ${old_ips_ip ?? `${old_usernames_ip} (from previous oiproctor session)`} > ${ip}`);
		}
		console.log([ date_formatted(), ip, username, ].join('\t'));

		users_map.ips[ip] = user_obj;

		fs.writeFileSync(
			config.proctor_users_path,
			JSON.stringify(users_map),
		);

		exec('killall -s SIGHUP dnsmasq');

	};

	const status = (req, res) => {

		const now = Date.now();

		const nocache = params.get('nocache');
		if (!nocache && cache.status?.timestamp > now - config.ping_interval / 2 * 1000) return res.write(cache.status.output);

		let output = "";
		output	+= `<!DOCTYPE html><html><head><title>${config.title}</title><meta http-equiv="refresh" content="${config.ping_interval}"></head><body>`;

		output	+= '<style>.user { display: inline-block; float: left; padding: 1em; text-align: center; min-width: 5em; border: 1px dotted grey; font-family: monospace; } .first { clear: left; } .online { background-color: green; color: white; } .offline { background-color: red; } .idle { background-color: yellow; }</style>';

		let old_team;
		[ ...new Set(config.cms_users) ].sort().forEach(username => {

			const team     	= username.substring(0, 2);

			const user_obj 	= Object.values(users_map.ips).find((user_obj) => user_obj.username === username);

			let user_ip    	= user_obj?.ip;
			if (!user_ip) user_ip = "";

			let classname  	= 'user';
			if (user_obj?.timestamp >= now - config.ping_interval * 2 * 1000) {
				classname += ' online';
			} else if (user_obj || !!users_map.usernames[username]) {
				classname += ' idle';
			} else {
				classname += ' offline';
			}

			if (old_team != team) {
				classname += ' first';
			}

			output        	+=`<div class="${classname}" title="${user_ip}">${username}</div>`;

			old_team       	= team;

		});

		output	+= '</body></html>';
		res.write(output);

		cache.status = { output: output, timestamp: now };

	}

	if (req.url.startsWith('/status')) status(req, res);
	else if (req.url.startsWith('/update')) update(req, res);
	else if (req.url.startsWith('/alerts')) monitor(req, res);
	else if (req.url.startsWith('/notify')) notify(req, res);

    res.end();

};

try {

	const data = fs.readFileSync(CONFIG_PATH, 'utf8');
	data.split('\n').forEach(line => {
		line = line.trim();
		if (line.startsWith('#') || !line) return;
		const [ k, v ]  = line.split('=');
		const param 	= k.toLowerCase().replace(/^users_monitor_/, '');
		config[param]   = process.env[k] ?? (v.startsWith('"') && v.endsWith('"') ? v.substring(1, v.length - 1) : v);
	});
	for (let k of MANDATORY_PARAMS) {
		if (config[k] !== undefined) continue;
		const envParam = k.toUpperCase();
		config[k] = process.env[envParam] ?? process.env['USERS_MONITOR_' + envParam];
	}
	[ 'listen_port', 'ping_interval' ].forEach(k => config[k] = parseInt(config[k]));
	[ 'cms_users' ].forEach(k => config[k] = config[k].split(' ').map(v => v.trim()).filter(v => v));
	for (let k of MANDATORY_PARAMS) if (!config[k]) return console.error(`Missing mandatory parameter ${k} in config file ${CONFIG_PATH}`);

	try {
		const users_map_json = fs.readFileSync(config.proctor_users_path, 'utf8');
		users_map = JSON.parse(users_map_json);
	} catch (err) {
		// File does not exist yet or is invalid, start with empty map
	}

	http.createServer(requestListener).listen(config.listen_port, config.listen_host, () => {});

} catch (err) {
    console.error(`Failed to read config file ${CONFIG_PATH}: ${err}`);
}
