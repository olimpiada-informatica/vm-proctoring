# Environment variables have precedence over these values

PROCTOR_SERVER_PATH="/opt/oiproctor/bin/httptun/server.py"
PROCTOR_TUNNEL_PASS_PATH="/opt/oiproctor/etc/tunnel.pwd"
PROCTOR_LOG_HTTPTUN_PATH="/opt/oiproctor/log/httptun.log"
PROCTOR_CONNECTIONS_PATH="/opt/oiproctor/run/connections"
PROCTOR_ALIAS_PATH="/opt/oiproctor/run/alias"
PROCTOR_USERS_PATH="/opt/oiproctor/run/users"
PROCTOR_LOG_USERS_PATH="/opt/log/oiproctor_users.log"
USERS_MONITOR_LISTEN_PORT="81"
USERS_MONITOR_LISTEN_HOST="0.0.0.0"
USERS_MONITOR_PING_INTERVAL="60"
USERS_MONITOR_UPDATE_ALLOWLIST="^10\.9\."
VM_PROCTOR_USER="oi"
VM_PROCTOR_PRIVKEY_PATH="/opt/oiproctor/etc/vmkey.pwd"
VM_PROCTOR_DIFF_IGNORE_PATH="/home/$VM_PROCTOR_USER/oiproctor_diff.ignore"
VM_CONTESTANT_USER="contestant"

# Customize for your contest the following values, here or through docker compose's `.env` file
# Password for the communication tunnel between the proctoring server and the VMs. It must be the same as the variable `PROCTOR_TUNNEL_PASSWORD` in the VMs' `/etc/oisetup/profiles/`
TUNNEL_PASS=
# Private key to connect against the VMs through SSH
VM_SSH_PASS=
# Password to access the proctoring server's shell
OIPROCTOR_PASS=
# Title of the users monitor page
USERS_MONITOR_TITLE="Contest"
# Title in VM dialog windows
VM_DIALOG_TITLE="Contest"
# Contest's CMS shortname
CMS_CONTEST_SHORTNAME="contest"
# CMS users to monitor
CMS_USERS="user01 user02 user03 user04 user05 user06 user07 user08 user09 user10"
