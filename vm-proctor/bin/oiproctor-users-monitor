#!/bin/node

const CONFIG_PATH   	= '/opt/oiproctor/etc/config';
const MANDATORY_PARAMS  = [ 'listen_port', 'listen_host', 'cms_contest_shortname', 'proctor_connections_path', 'proctor_users_path', 'proctor_log_users_path', 'title', 'ping_interval', 'update_allowlist', 'cms_users' ];

const http  	= require('http');
const fs    	= require('fs');
const { exec }	= require("child_process");

const config	= {};
var users_map   = {};
var cache   	= {};
var alerts      = [];

function date_formatted(date = new Date()) {

	const now   	= typeof date === 'object' ? date : new Date(date);

	const year  	= now.getFullYear();
	const month 	= String(now.getMonth() + 1).padStart(2, '0');
	const day   	= String(now.getDate() 	).padStart(2, '0');
	const hours 	= String(now.getHours()	).padStart(2, '0');
	const minutes   = String(now.getMinutes()  ).padStart(2, '0');
	const seconds   = String(now.getSeconds()  ).padStart(2, '0');

	return year + '-' + month + '-' + day + ' ' + hours + ':' + minutes + ':' + seconds;

}

function add_alert(ip, msg) {

	alerts.push({ timestamp: Date.now(), ip: ip, message: msg });

	const msg_text = [ date_formatted(), ip, msg, ].join('\t');
	fs.appendFileSync(
		config.proctor_log_users_path,
		msg_text + '\n',
	);
	console.warn(msg_text);

}

const requestListener = function (req, res) {

	const params = new URLSearchParams(req.url.split('?').slice(1).join('?'));

	const monitor = (req, res) => {

		const since       = parseInt(params.get('since'));

		let output = "";
		output  += `<!DOCTYPE html><html><head><title>${config.title}</title><meta http-equiv="refresh" content="${config.ping_interval}"></head><body>`;

		output  += '<style>.timestamp, .user, .message { display: inline-block; margin: 0 1em; }</style>';

		alerts.forEach(alert => {
			if (since && alert.timestamp < since) return;
			output += `<div><div class="timestamp">${date_formatted(alert.timestamp)}</div><div class="user">${alert.ip}</div><div class="message">${alert.message}</div></div>`;
		});

		output  += '</body></html>';
		res.write(output);

	};

	const notify = (req, res) => {

		const msg       = params.get('msg');

		if (!msg) return res.write('{ "error": "Missing msg" }');

		const ip        = req.headers['x-forwarded-for'] || req.socket.remoteAddress;

		if (!ip.match(new RegExp(config.update_allowlist)) && !ip.match(new RegExp(config.update_whitelist))) return console.error(`Invalid source IP ${ip} trying to notiy ${msg}`);

		add_alert(ip, msg);

		res.write('{ "success": true }');

	};

	const update = (req, res) => {

		const username 	= params.get(config.cms_contest_shortname + '_login');

		if (!username) return;
		if (!config.cms_users.includes(username)) return; // Whitelist to prevent http requests poisoning the dns

		const ip    	= req.headers['x-forwarded-for'] || req.socket.remoteAddress;

		if (!ip.match(new RegExp(config.update_allowlist)) && !ip.match(new RegExp(config.update_whitelist))) return console.error(`Invalid source IP ${ip} trying to register ${username}`);

		if (users_map[ip]?.username === username) {
			users_map[ip].timestamp = Date.now();
			return;
		}

		const old_ip_username = users_map[ip]?.username;
		const old_username_ip = Object.keys(users_map).find((ip) => users_map[ip].username == username);

		if (old_ip_username != username) {
			add_alert(ip, `Known IP switched user: ${old_ip_username} > ${username}`);
		}
		if (old_username_ip !== ip) {
			add_alert(ip, `Known user found in new IP: ${username} ${old_username_ip} > ${ip}`);
		}
		console.log([ date_formatted(), ip, username, ].join('\t'));

		const user_obj  = { username, ip, timestamp: Date.now(), };
		users_map[ip] = user_obj;
		if (old_username_ip !== ip) {
			delete users_map[old_username_ip];
		}

		fs.writeFileSync(
			config.proctor_users_path,
			Object.entries(users_map).reduce((acc, [ ip, user_obj ]) => {
				const username = user_obj.username;
				acc += ip + ' ' + username + '\n';
				return acc;
			}, ''),
		); // Must be in hosts file format, as it is used by dnsmasq and oiproctor

		exec('killall -s SIGHUP dnsmasq');

	};

	const status = (req, res) => {

		const now = Date.now();

		const nocache = params.get('nocache');
		if (!nocache && cache.status?.timestamp > now - config.ping_interval / 2 * 1000) return res.write(cache.status.output);

		let output = "";
		output += `<!DOCTYPE html><html><head><title>${config.title}</title><meta http-equiv="refresh" content="${config.ping_interval}"></head><body>`;

		output += '<style>.user { display: inline-block; float: left; padding: 1em; text-align: center; min-width: 5em; border: 1px dotted grey; font-family: monospace; } .first { clear: left; } .online { background-color: green; color: white; } .offline { background-color: red; } .idle { background-color: yellow; } .users:not(.detailed) .user_details:not(.username) { display: none; }</style>';

		output += '<div class="users">';

		let old_team;
		[ ...new Set(config.cms_users) ].sort().forEach(username => {

			const team     	= username.substring(0, 2);

			const user_obj 	= Object.values(users_map).find((user_obj) => user_obj.username === username);

			let user_ip    	= user_obj?.ip;
			if (!user_ip) user_ip = "";

			let classname  	= 'user';
			const timestamp = user_obj?.timestamp;
			if (timestamp >= now - config.ping_interval * 2 * 1000) {
				classname += ' online';
			} else if (user_obj) {
				classname += ' idle';
			} else {
				classname += ' offline';
			}

			if (old_team != team) {
				classname += ' first';
			}

			output +=`<div class="${classname}"><div class="user_details username">${username || ''}</div><div class="user_details user_ip">${user_ip || ''}</div><div class="user_details timestamp">${timestamp || ''}</div><div class="user_details datetime">${timestamp ? date_formatted(timestamp) : ''}</div></div>`;

			old_team       	= team;

		});

		output += '</div>';

		output += '<script>var showTitles = 0; const checkAndTriggerTitles = () => { if (showTitles % 2 == 0 && showTitles > 3) document.querySelector(".users").classList.add("detailed"); }; document.querySelector(".users > div:first-of-type").addEventListener("click", () => { if (showTitles % 2 == 0) showTitles++; checkAndTriggerTitles(); }); document.querySelector(".users > div:last-of-type").addEventListener("click", () => { if (showTitles % 2 == 1) showTitles++; checkAndTriggerTitles(); });</script>';

		output += '</body></html>';
		res.write(output);

		cache.status = { output: output, timestamp: now };

	}

	if (req.url.startsWith('/status')) status(req, res);
	else if (req.url.startsWith('/update')) update(req, res);
	else if (req.url.startsWith('/alerts')) monitor(req, res);
	else if (req.url.startsWith('/notify')) notify(req, res);

    res.end();

};

try {

	const data = fs.readFileSync(CONFIG_PATH, 'utf8');
	data.split('\n').forEach(line => {
		line = line.trim();
		if (line.startsWith('#') || !line) return;
		const [ key, ...v ]  = line.split('=');
		const value     = v.join();
		const param 	= key.toLowerCase().replace(/^users_monitor_/, '');
		config[param]   = process.env[key] ?? (value.startsWith('"') && value.endsWith('"') ? value.substring(1, value.length - 1) : value);
	});
	for (let k of MANDATORY_PARAMS) {
		if (config[k] !== undefined) continue;
		const envParam = k.toUpperCase();
		config[k] = process.env[envParam] ?? process.env['USERS_MONITOR_' + envParam];
	}
	[ 'listen_port', 'ping_interval' ].forEach(k => config[k] = parseInt(config[k]));
	[ 'cms_users' ].forEach(k => config[k] = config[k].split(' ').map(v => v.trim()).filter(v => v));
	for (let k of MANDATORY_PARAMS) if (!config[k]) return console.error(`Missing mandatory parameter ${k} in config file ${CONFIG_PATH}`);

	try {
		const users_hosts_file = fs.readFileSync(config.proctor_users_path, 'utf8');
		for (const rawLine of users_hosts_file.split(/\r?\n/)) {
  			const line = rawLine.trim();
  			if (!line || line.startsWith('#')) continue; // skip empty lines and comments
  			const parts = line.split(/\s+/);
  			if (parts.length !== 2) continue; // Invalid format
  			const [ ip, username, ] = parts;
  			if (users_map[ip]) continue; // If the username is assigned to multiple IPs, keep only the first one
    			const user_obj = { username, ip, };
    			users_map[ip] = user_obj;
		}
	} catch (err) {
		// File does not exist yet or is invalid, start with empty map
	}

	http.createServer(requestListener).listen(config.listen_port, config.listen_host, () => {});

} catch (err) {
    console.error(`Failed to read config file ${CONFIG_PATH}: ${err}`);
}
